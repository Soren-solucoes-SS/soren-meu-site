                        <a class="btn" href="https://youtu.be/mQWUogSqfqU" target="_blank" rel="noopener">
                            Abrir no YouTube
                        </a>
                    </div>
                </div>
            </article>

            <article class="video-card">
                <div class="video-frame">
                    <!-- Embed do YouTube -->
